NODE_ENV=development


PORT=8000

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name

ACCESS_TOKEN_SECRET=your_secure_access_token_secret_min_32_chars
ACCESS_TOKEN_EXPIRY=1d

REFRESH_TOKEN_SECRET=your_secure_refresh_token_secret_min_32_chars
REFRESH_TOKEN_EXPIRY=7d

CORS_ORIGIN=http://localhost:5173

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Configuration
# Local development: Gmail App Password is OK for testing.
# Production: prefer SMTP_URL from your email provider or a dedicated SMTP service.
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_16_char_app_password

# Production SMTP option (recommended for Render / hosted deployments)
# Example: smtp://username:password@smtp.example.com:587
SMTP_URL=

# Optional provider-specific overrides
# EMAIL_FROM=notifications@yourdomain.com
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=notifications@yourdomain.com
# SENDGRID_FROM_NAME=ChatApp Support
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
# EMAIL_REPLY_TO=support@yourdomain.com

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:8000/api/v1/user/auth/google/callback

